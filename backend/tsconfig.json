{
  "compilerOptions": {
    "target": "ES6", // Set the target JavaScript version
    "module": "ESNext", // Set the module system
    "rootDir": "./src", // Specify the root directory of input files
    "outDir": "./dist", // Specify the output directory for compiled files
    "typeRoots": ["./node_modules/@types"], // Specify the types directory
    "esModuleInterop": true, // Enable interoperability between CommonJS and ES modules
    "strict": true, // Enable all strict type-checking options
    "skipLibCheck": true // Skip type checking of declaration files
  },
  "include": ["./src/**/*", "./types/**/*"],
  "files": ["./types/global.d.ts"]
}
